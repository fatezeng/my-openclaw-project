<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black">

    <!-- 底层：全屏摄像头预览画面 -->
    <androidx.camera.view.PreviewView
        android:id="@+id/previewView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- 中层：半透明参考线网格 -->
    <!-- 暂时移除参考线网格，简化实现 -->

    <!-- 上层：中间距离显示区域 -->
    <RelativeLayout
        android:id="@+id/middleLayer"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@android:color/transparent"
        android:clickable="false"
        android:focusable="false"
        android:focusableInTouchMode="false"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- 中心对准指示器 -->
        <View
            android:id="@+id/centerIndicator"
            android:layout_width="200dp"
            android:layout_height="200dp"
            android:layout_centerInParent="true"
            android:background="@drawable/center_indicator"
            android:clickable="false"
            android:focusable="false"
            android:focusableInTouchMode="false" />

        <!-- 距离显示文本 -->
        <TextView
            android:id="@+id/distanceText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:layout_marginTop="120dp"
            android:text="距离: 检测中"
            android:textColor="@color/white"
            android:textSize="24sp"
            android:fontFamily="sans-serif-bold"
            android:background="@android:color/transparent"
            android:clickable="false"
            android:focusable="false"
            android:focusableInTouchMode="false" />

        <!-- 操作指南文本 -->
        <TextView
            android:id="@+id/guideText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_centerHorizontal="true"
            android:layout_below="@id/centerIndicator"
            android:layout_marginTop="20dp"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:text="请将腰部对准中心，点击开始测量"
            android:textColor="@color/white_60"
            android:textSize="14sp"
            android:fontFamily="sans-serif-medium"
            android:background="@android:color/transparent"
            android:clickable="false"
            android:focusable="false"
            android:focusableInTouchMode="false"
            android:gravity="center"
            android:maxLines="2"
            android:ellipsize="none" />

    </RelativeLayout>

    <!-- 上层：顶部状态栏区域 -->
    <RelativeLayout
        android:id="@+id/topLayer"
        android:layout_width="0dp"
        android:layout_height="160dp"
        android:background="@android:color/transparent"
        android:clickable="false"
        android:focusable="false"
        android:focusableInTouchMode="false"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- 状态图标 -->
        <ImageView
            android:id="@+id/statusIcon"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_centerHorizontal="true"
            android:layout_marginTop="16dp"
            android:src="@drawable/ic_check_circle"
            android:tint="@color/white"
            android:visibility="gone" />
        
        <!-- 进度指示器 -->
        <LinearLayout
            android:id="@+id/progressContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_centerHorizontal="true"
            android:layout_marginTop="40dp"
            android:layout_marginStart="32dp"
            android:layout_marginEnd="32dp"
            android:orientation="horizontal"
            android:gravity="center"
            android:visibility="gone">
            
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="完成进度"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:fontFamily="sans-serif-medium"
                android:layout_marginEnd="16dp" />
            
            <ProgressBar
                android:id="@+id/captureProgressBar"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="0dp"
                android:layout_height="12dp"
                android:layout_weight="1"
                android:indeterminate="false"
                android:max="100"
                android:progress="0"
                android:progressDrawable="@drawable/horizontal_progress"
                android:visibility="visible" />
            
            <TextView
                android:id="@+id/tvProgressPercent"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0%"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:fontFamily="sans-serif-medium"
                android:layout_marginStart="16dp" />
        </LinearLayout>

        <!-- 状态文本 -->
        <TextView
            android:id="@+id/statusText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_centerHorizontal="true"
            android:layout_marginTop="72dp"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:text="摄像头就绪，点击开始扫描"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:fontFamily="sans-serif-medium"
            android:background="@android:color/transparent"
            android:clickable="false"
            android:focusable="false"
            android:focusableInTouchMode="false"
            android:gravity="center"
            android:maxLines="3"
            android:ellipsize="none" />

        <!-- 操作指南按钮 -->
        <ImageButton
            android:id="@+id/btnGuide"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_alignParentRight="true"
            android:layout_marginTop="16dp"
            android:layout_marginRight="16dp"
            android:background="@android:color/transparent"
            android:src="@drawable/ic_info"
            android:tint="@color/white"
            android:clickable="true"
            android:focusable="true" />

    </RelativeLayout>



    <!-- 上层：底部按钮区域 -->
    <RelativeLayout
        android:id="@+id/bottomLayer"
        android:layout_width="0dp"
        android:layout_height="200dp"
        android:background="@android:color/transparent"
        android:clickable="false"
        android:focusable="false"
        android:focusableInTouchMode="false"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- 白圆线 -->
        <View
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:layout_centerHorizontal="true"
            android:layout_alignParentBottom="true"
            android:layout_marginBottom="52dp"
            android:background="@drawable/circle_stroke"
            android:clickable="false"
            android:focusable="false"
            android:focusableInTouchMode="false" />

        <!-- 白色圆形按钮 -->
        <View
            android:id="@+id/actionButton"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_centerHorizontal="true"
            android:layout_alignParentBottom="true"
            android:layout_marginBottom="68dp"
            android:background="@drawable/circle_background"
            android:clickable="true"
            android:focusable="true" />
        
        <!-- 扫描完成视觉反馈元素 -->
        <View
            android:id="@+id/scanCompleteIndicator"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_centerHorizontal="true"
            android:layout_alignParentBottom="true"
            android:layout_marginBottom="68dp"
            android:background="@drawable/red_square"
            android:visibility="gone"
            android:clickable="false"
            android:focusable="false"
            android:focusableInTouchMode="false" />

        <!-- 瞬形按钮 -->
        <TextView
            android:id="@+id/tvShunXing"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_toRightOf="@+id/actionButton"
            android:layout_alignTop="@+id/actionButton"
            android:layout_marginLeft="48dp"
            android:text="瞬形"
            android:textColor="@color/primary"
            android:textSize="18sp"
            android:fontFamily="sans-serif-bold"
            android:clickable="true"
            android:focusable="true" />

    </RelativeLayout>

    <!-- 操作指南对话框 -->
    <RelativeLayout
        android:id="@+id/guideDialog"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@color/black_opacity_70"
        android:clickable="true"
        android:focusable="true"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:layout_marginStart="24dp"
            android:layout_marginEnd="24dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="10dp"
            app:cardBackgroundColor="@color/white">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="28dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="测量指南"
                    android:textSize="24sp"
                    android:fontFamily="sans-serif-bold"
                    android:textColor="@color/primary"
                    android:layout_marginBottom="20dp"
                    android:shadowColor="@color/black"
                    android:shadowDx="0"
                    android:shadowDy="2"
                    android:shadowRadius="4" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="准备工作："
                    android:textSize="18sp"
                    android:fontFamily="sans-serif-bold"
                    android:textColor="@color/dark"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="1. 请站在摄像头前约1-2米处，确保全身在画面中"
                    android:textSize="16sp"
                    android:fontFamily="sans-serif-medium"
                    android:textColor="@color/dark"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="2. 穿着贴身衣物，露出腰部，避免宽松衣物影响测量"
                    android:textSize="16sp"
                    android:fontFamily="sans-serif-medium"
                    android:textColor="@color/dark"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="3. 确保光线充足，避免背光或过暗环境"
                    android:textSize="16sp"
                    android:fontFamily="sans-serif-medium"
                    android:textColor="@color/dark"
                    android:layout_marginBottom="20dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="测量步骤："
                    android:textSize="18sp"
                    android:fontFamily="sans-serif-bold"
                    android:textColor="@color/dark"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="1. 点击开始测量按钮"
                    android:textSize="16sp"
                    android:fontFamily="sans-serif-medium"
                    android:textColor="@color/dark"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="2. 将腰部对准摄像头中心的椭圆环"
                    android:textSize="16sp"
                    android:fontFamily="sans-serif-medium"
                    android:textColor="@color/dark"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="3. 保持身体稳定，缓慢旋转360度"
                    android:textSize="16sp"
                    android:fontFamily="sans-serif-medium"
                    android:textColor="@color/dark"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="4. 等待系统自动拍摄30张照片"
                    android:textSize="16sp"
                    android:fontFamily="sans-serif-medium"
                    android:textColor="@color/dark"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="5. 测量完成后，系统将自动生成结果"
                    android:textSize="16sp"
                    android:fontFamily="sans-serif-medium"
                    android:textColor="@color/dark"
                    android:layout_marginBottom="20dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="注意事项："
                    android:textSize="18sp"
                    android:fontFamily="sans-serif-bold"
                    android:textColor="@color/dark"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="• 保持身体直立，放松腹部"
                    android:textSize="16sp"
                    android:fontFamily="sans-serif-medium"
                    android:textColor="@color/dark"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="• 双脚与肩同宽，保持稳定"
                    android:textSize="16sp"
                    android:fontFamily="sans-serif-medium"
                    android:textColor="@color/dark"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="• 旋转过程中保持腰部在画面中心"
                    android:textSize="16sp"
                    android:fontFamily="sans-serif-medium"
                    android:textColor="@color/dark"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="• 避免快速移动或晃动手机"
                    android:textSize="16sp"
                    android:fontFamily="sans-serif-medium"
                    android:textColor="@color/dark"
                    android:layout_marginBottom="28dp" />

                <Button
                    android:id="@+id/btnCloseGuide"
                    android:layout_width="wrap_content"
                    android:layout_height="52dp"
                    android:layout_gravity="end"
                    android:text="我知道了"
                    android:textSize="18sp"
                    android:fontFamily="sans-serif-bold"
                    android:backgroundTint="@color/primary"
                    android:textColor="@color/white"
                    android:clickable="true"
                    android:focusable="true"
                    android:elevation="4dp" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

    </RelativeLayout>

</androidx.constraintlayout.widget.ConstraintLayout>