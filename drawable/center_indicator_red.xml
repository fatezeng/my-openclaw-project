<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- 外圆 -->
    <item>
        <shape android:shape="oval">
            <stroke
                android:width="2dp"
                android:color="@color/error"
                android:dashWidth="10dp"
                android:dashGap="5dp" />
        </shape>
    </item>
    <!-- 内圆 -->
    <item
        android:top="40dp"
        android:left="40dp"
        android:right="40dp"
        android:bottom="40dp">
        <shape android:shape="oval">
            <stroke
                android:width="2dp"
                android:color="@color/error" />
        </shape>
    </item>
    <!-- 十字线 -->
    <item>
        <rotate
            android:fromDegrees="0"
            android:toDegrees="0"
            android:pivotX="50%"
            android:pivotY="50%">
            <shape android:shape="line">
                <stroke
                    android:width="2dp"
                    android:color="@color/error" />
            </shape>
        </rotate>
    </item>
    <item>
        <rotate
            android:fromDegrees="90"
            android:toDegrees="90"
            android:pivotX="50%"
            android:pivotY="50%">
            <shape android:shape="line">
                <stroke
                    android:width="2dp"
                    android:color="@color/error" />
            </shape>
        </rotate>
    </item>
</layer-list>